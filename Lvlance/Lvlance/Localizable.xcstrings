          "stringUnit" : {
            "state" : "translated",
            "value" : "Place the input device in the desired location"
          }
        }
      }
    },
    "이 곡에서 연주할 악기를 선택해주세요." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please select the instruments to be played in this song"
          }
        }
      }
    },
    "이 기기가 입력한 밴드의 소리는 악기별로 분류되어 앱 내에 반영됩니다." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
