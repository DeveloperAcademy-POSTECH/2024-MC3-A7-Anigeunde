    "onboarding.step1.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Place the iPhone in front of the speaker facing the audience to capture the full sound of the band"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "밴드의 전체 소리를 입력할 iPhone을 관객 쪽을 향하는 스피커의 앞에 둡니다."
          }
        }
      }
    },
    "onboarding.step2.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connect the iPhone to the MacBook with a cable to capture the full sound of the band"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "밴드의 전체 소리를 입력할 iPhone을 macBook에 선으로 연결합니다."
          }
        }
      }
    },
    "onboarding.step3.description1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lvlance is an app that allows performers to visually monitor the full sound of the band as heard by the audience during a performance "
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lvlance는 밴드 연주 중, 관객에게 들리는 밴드의 전체 소리를 연주자가 시각적으로 알 수 있는 앱입니다"
          }
        }
      }
    },
    "onboarding.step3.description2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " Connect your input device now and start using Lvlance!"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지금 바로 입력 기기를 연결하여 Lvlance를 사용해 보세요!"
          }
        }
      }
    },
