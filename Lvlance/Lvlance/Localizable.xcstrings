        }
      }
    },
    "밴드의 전체 소리를 입력할 기기를 선택해주세요. (권장 기기: iPhone)" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose a device to input the entire sound of the band. (Recommended device: iPhone)"
          }
        }
      }
    },
