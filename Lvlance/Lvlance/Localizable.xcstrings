          "stringUnit" : {
            "state" : "translated",
            "value" : "Done"
          }
        }
      }
    },
    "선택하신 디바이스로 밴드의 연주 소리를 입력받습니다." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The device you've selected will input the sound of the band's performance."
          }
        }
      }
    },
    "악기 편집하기" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Edit Instruments"
          }
        }
      }
    },
    "연주를 완료하고 이전 화면으로 이동하시겠어요?" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do you want to complete the performance and go to the previous screen?"
          }
        }
      }
    },
    "완료" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Done"
          }
        }
      }
    },
    "원하는 위치에 입력 기기를 놓아주세요." : {
